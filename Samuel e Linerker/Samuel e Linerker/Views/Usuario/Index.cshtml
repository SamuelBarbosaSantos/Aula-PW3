@model IEnumerable<Samuel_e_Linerker.Models.Usuario>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a class="btn btn-primary" asp-action="CadastrarUsuario" asp-controller="Usuario">Cadastrar</a>
</p>
<div class="table-responsive">
<table class="table table-bordered">
    <thead>
        <tr>
            <th scope="col">@Html.DisplayNameFor(Model => Model.IdUsu)</th>
            <th scope="col">@Html.DisplayNameFor(Model => Model.nomeUsu)</th>
            <th scope="col">@Html.DisplayNameFor(Model => Model.Cargo)</th>
            <th scope="col">@Html.DisplayNameFor(Model => Model.DataNasc)</th>
            <th scope="col">Ação</th>
        </tr>
    </thead>
    <tbody>
@foreach (Usuario usuario in Model) {
        <tr>
            <td>@usuario.IdUsu</td>
            <td>@usuario.nomeUsu</td>
            <td>@usuario.Cargo</td>
            <td>@usuario.DataNasc.ToString("dd/mm/yyyy")</td>
            <td>
                @Html.ActionLink("Edit", "Edit", new { /* id=item.PrimaryKey */ }) |
                @Html.ActionLink("Details", "Details", new { /* id=item.PrimaryKey */ }) |
                @Html.ActionLink("Delete", "Delete", new { /* id=item.PrimaryKey */ })
            </td>
        </tr>
}
    </tbody>

  </table>
</div>
